# Server
PORT=8080
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:5173

# AI provider — one of: gemini | openai | mock
# Gemini has a generous free tier — recommended default.
AI_PROVIDER=gemini

# Gemini (Google AI Studio — free key at https://aistudio.google.com/apikey)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite

# OpenAI (optional fallback)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Extraction tuning
BATCH_SIZE=20
AI_CONCURRENCY=3
AI_MAX_RETRIES=2
AI_TIMEOUT_MS=45000

# Upload
MAX_UPLOAD_MB=10

# Import cache (in-memory TTL, minutes)
IMPORT_CACHE_TTL_MIN=15

# Persistence — MongoDB (Atlas or local; optional).
# Leave blank to run stateless.
# Local example : mongodb://localhost:27017/groweasy
# Atlas example : mongodb+srv://<user>:<pass>@cluster0.abcd.mongodb.net/?retryWrites=true&w=majority
MONGODB_URI=
MONGODB_DB=groweasy
